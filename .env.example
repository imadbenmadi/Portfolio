# ────────────────────────────────────────────────────────────────
# Vercel Postgres — added automatically when you attach the DB
# ────────────────────────────────────────────────────────────────
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ────────────────────────────────────────────────────────────────
# Vercel Blob — added automatically when you attach Blob storage
# ────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ────────────────────────────────────────────────────────────────
# Admin credentials — set MANUALLY in Vercel Dashboard
# Never commit real values here!
# ────────────────────────────────────────────────────────────────

# The username you'll type on the login page
ADMIN_USERNAME=imad

# bcrypt hash of your password — generate it with:
#   node scripts/generate-hash.js yourpassword
ADMIN_PASSWORD_HASH=$2a$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A long random string used to sign JWT tokens
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret
